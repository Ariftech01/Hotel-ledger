{
  "expo": {
    "name": "Hotel Ledger Pro",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1E3A8A"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#1E3A8A",
      "package": "com.arif.hotelledger"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d2c47027-0554-4f19-bf5e-6c50d5eebd99"
      }
    }
  }
}
